{{- if and (has "rustup" .software_checks) (eq .chezmoi.os "linux") }}
source $"($nu.home-dir)/.cargo/env.nu"
{{- end }}

poof init --shell nushell | save -f ~/.cache/nushell/poof.nu

# FIXME save to XDG_CACHE_HOME

{{- if has "carapace" .software_checks}}
$env.CARAPACE_BRIDGES = 'zsh,fish,bash,inshellisense' # optional
carapace _carapace nushell | save --force ~/.cache/nushell/carapace.nu
{{- end }}

{{- if has "starship" .software_checks}}
starship init nu | save -f ~/.cache/nushell/starship.nu
{{- end }}

{{- if has "starship" .software_checks}}
$env.LS_COLORS = (vivid generate ansi)
{{- end }}

{{- if has "zoxide" .software_checks}}
zoxide init nushell | save -f ~/.cache/nushell/zoxide.nu
{{- end }}

{{- if has "uv" .software_checks}}
uv generate-shell-completion nushell | save -f ~/.cache/nushell/uv.nu
{{- end }}
