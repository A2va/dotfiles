def "save-ensure" [filepath: string] {
    let expanded_path = ($filepath | path expand)
    let dir = ($expanded_path | path dirname)

    if not ($dir | path exists) {
        mkdir $dir
    }

    $in | save --force $expanded_path
}

# FIXME save to XDG_CACHE_HOME
let cache_dir = "~/.cache/nushell" | path expand

{{- if and (has "rustup" .software_checks) (eq .chezmoi.os "linux") }}
source $"($nu.home-dir)/.cargo/env.nu"
{{- end }}

let poof_file = $cache_dir | path join "poof.nu"
if not ($poof_file | path exists) {
    # Might need to add poof path manually
    # $env.PATH = ($env.PATH | prepend "/home/a2va/.local/share/poof/bin")
    poof init --shell nushell | save-ensure ~/.cache/nushell/poof.nu
}

{{- if has "carapace-bin" .software_checks}}
let carapace_file = $cache_dir | path join "carapace.nu"
if not ($carapace_file | path exists) {
    $env.CARAPACE_BRIDGES = 'zsh,fish,bash,inshellisense' # optional
    carapace _carapace nushell | save-ensure $carapace_file
}
{{- end }}

{{- if has "starship" .software_checks}}
let starship_file = $cache_dir | path join "starship.nu"
if not ($carapace_file | path exists) {
    starship init nu | save-ensure $starship_file
}
{{- end }}

{{- if has "vivid" .software_checks}}
$env.LS_COLORS = (vivid generate ansi)
{{- end }}

{{- if has "zoxide" .software_checks}}
let zoxide_file = $cache_dir | path join "zoxide.nu"
if not ($zoxide_file | path exists) {
    zoxide init nushell | save-ensure $zoxide_file
}
{{- end }}

{{- if has "uv" .software_checks}}
let uv_file = $cache_dir | path join "uv.nu"
if not ($uv_file | path exists) {
    uv generate-shell-completion nushell | save-ensure $uv_file
}
{{- end }}
