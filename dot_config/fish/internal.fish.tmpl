set -x STARSHIP_LOG  "error"

poof init --shell fish | source

# Setup cli tools
{{- if has "carapace-bin" .software_checks }}
# carapace completion
set -Ux CARAPACE_BRIDGES 'zsh,fish,bash,inshellisense' # optional
carapace _carapace | source
{{- end }}

{{- if has "starship" .software_checks }}
starship init fish | source
{{- end }}

{{- if has "vivid" .software_checks }}
set -gx LS_COLORS (vivid generate ansi)
{{- end }}

{{- if has "rustup" .software_checks }}
# rustup completion
source "$HOME/.cargo/env.fish"
rustup completions fish | source
{{- end }}

{{ if has "xmake" .software_checks }}
# xmake completion
source ~/.xmake/profile
{{ end }}

{{- if has "uv" .software_checks }}
# uv completion
uv generate-shell-completion fish
{{- end }}

{{- if has "zoxide" .software_checks }}
zoxide init fish | source
{{- end }}

{{- if has "fzf" .software_checks }}
fzf --fish | source
{{- end }}

{{- if has "rg" .software_checks }}
rg --generate=complete-fish | source
{{- end }}
