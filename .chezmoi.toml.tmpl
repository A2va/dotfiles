{{/* === Desktop Detection === */}}

{{- $isDesktop := false -}}

{{- if eq .chezmoi.os "windows" -}}
  {{- $editionOut := (output "powershell" "-Command" "(Get-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion').EditionID") -}}
  {{- $edition := (trim $editionOut) -}}
  {{- if or
        (eq $edition "Professional")
        (eq $edition "Home")
        (eq $edition "Core")
        (eq $edition "Education")
      -}}
    {{- $isDesktop = true -}}
  {{- end -}}
{{- else if or (ne (env "DISPLAY") "") (ne (env "WAYLAND_DISPLAY") "") (eq (env "XDG_SESSION_TYPE") "wayland") (eq (env "XDG_SESSION_TYPE") "x11") -}}
  {{- $isDesktop = true -}}
{{- end -}}


{{/* === Shell Selection === */}}

{{- $availableShells := list -}}
{{- $defaultShells := list -}}

{{- if eq .chezmoi.os "linux" }}
  {{- $availableShells = list "nushell" "fish" "bash" -}}
  {{- $defaultShells = list "fish" "bash" -}}
{{- else if eq .chezmoi.os "windows" }}
  {{- $availableShells = list "nushell" "powershell" -}}
  {{- $defaultShells = list "powershell" -}}
{{- end }}

{{- $shellPrompt := "Which shells do you want to configure? (Uninstalled shells will be installed automatically)" -}}
{{- $chosenShells := promptMultichoice $shellPrompt $availableShells $defaultShells -}}

{{/* === 2. Software Group Selection === */}}

{{- /* Read the file from your source directory */ -}}
{{- $packages := include ".chezmoidata/packages.yaml" | fromYaml -}}

{{- $promptLines := list "Select optional software groups ('base' is always installed):" -}}
{{- $availableGroups := list -}}
{{- $mandatoryGroups := list -}}

{{- range $group := $packages.groups -}}
  {{- $desktopOnly := false -}}
  {{- if hasKey $group "desktop_only" -}}
    {{- $desktopOnly = $group.desktop_only -}}
  {{- end -}}


  {{- /* Check if the group is allowed based on desktop status */ -}}
  {{- if or (not $desktopOnly) $isDesktop -}}

    {{- if $group.optional -}}
      {{- /* Add to the user prompt */ -}}
      {{- $availableGroups = append $availableGroups $group.name -}}
      {{- $promptLines = append $promptLines (printf "  %-4s - %s" $group.name $group.description) -}}
    {{- else -}}
      {{- /* Silently add to mandatory list without asking */ -}}
      {{- $mandatoryGroups = append $mandatoryGroups $group.name -}}
    {{- end -}}

  {{- end -}}
{{- end -}}

{{- $prompt := join "\n" $promptLines -}}
{{- $chosenOptionalGroups := promptMultichoice $prompt $availableGroups (list) -}}

{{- /* Final chosen groups is the required groups + whatever the user selected */ -}}
{{- $chosenSoftwareGroups := concat $mandatoryGroups $chosenOptionalGroups -}}

{{/* === Software Checks === */}}

{{- $locationCheck := list -}}
{{- if eq .chezmoi.os "linux" }}
  {{- /* Dynamically generate paths to avoid hardcoded 'a2va' */ -}}
  {{- $poofBinPath := joinPath .chezmoi.homeDir ".local/share/poof/bin" -}}
  {{- $localBinPath := joinPath .chezmoi.homeDir ".local/bin" -}}
  {{- $locationCheck = list "bin" "/usr/bin" $localBinPath $poofBinPath -}}
{{- else if eq .chezmoi.os "windows" }}
  {{- $wingetLinksPath := joinPath .chezmoi.homeDir "AppData" "Local" "Microsoft" "WinGet" "Links" -}}
  {{- $locationCheck = list $wingetLinksPath -}}
{{- end }}

{{- $softwareChecks := list -}}

{{- /* Safely extract the 'poof' dictionary to avoid missing key errors */ -}}
{{- $poofPackages := dict -}}
{{- if hasKey $packages "packages" -}}
  {{- if hasKey $packages.packages "poof" -}}
    {{- $poofPackages = $packages.packages.poof -}}
  {{- end -}}
{{- end -}}

{{- /* Loop through the poof groups (base, dev, etc.) */ -}}
{{- range $groupName, $poofTools := $poofPackages -}}

  {{- /* Did the user choose this specific group? */ -}}
  {{- $isInChosenGroup := has $groupName $chosenSoftwareGroups -}}

  {{- range $pkg := $poofTools -}}

    {{- /* Extract the executable name by grabbing everything after the last '/' */ -}}
    {{- /* e.g., "github.com/typst/typst" -> "typst" */ -}}
    {{- $execName := base $pkg -}}

    {{- /* Check if the tool is installed on the system */ -}}
    {{- $isInstalled := or (lookPath $execName) (findExecutable $execName $locationCheck) -}}

    {{- /* If the group was chosen, OR the tool is already installed, add it to the list */ -}}
    {{- if or $isInChosenGroup $isInstalled -}}
      {{- $softwareChecks = append $softwareChecks $execName -}}
    {{- end -}}

  {{- end -}}
{{- end -}}

{{- /* === Extra Standalone Tools === */ -}}

{{- /* Tools that aren't managed by the poof list in packages.yaml */ -}}
{{- $extraTools := list "xmake" "poof" -}}

{{- range $tool := $extraTools -}}

  {{- /* Check if the tool is already installed */ -}}
  {{- $isInstalled := or (lookPath $tool) (findExecutable $tool $locationCheck) -}}

  {{- /* Manual check: If the tool is xmake, it belongs to the 'dev' group */ -}}
  {{- $isInChosenGroup := false -}}
  {{- if eq $tool "xmake" -}}
    {{- $isInChosenGroup = has "dev" $chosenSoftwareGroups -}}
  {{- end -}}

  {{- /* If installed, OR if its group was chosen, add it to softwareChecks */ -}}
  {{- if or $isInstalled $isInChosenGroup -}}
    {{- $softwareChecks = append $softwareChecks $tool -}}
  {{- end -}}

{{- end -}}


{{- /* Ensure there are no duplicate entries */ -}}
{{- $softwareChecks = $softwareChecks | uniq -}}

[data]
shells = {{ $chosenShells | toToml }}
software_groups = {{ $chosenSoftwareGroups | toToml }}
software_checks = {{ $softwareChecks | toToml }}
is_desktop = {{ $isDesktop | toToml }}
