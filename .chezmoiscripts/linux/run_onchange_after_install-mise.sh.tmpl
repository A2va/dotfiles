#! /bin/bash

# --- CHEZMOI TRIGGERS ---
# The script will re-run whenever any of these inputs change:
# packages.yaml hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }}
# mise template hash: {{ include "dot_config/mise/config.toml.tmpl" | sha256sum }}
# Chosen groups: {{ .software_groups | join "," }}

echo "Mise configuration updated. Running mise install..."
# Uses absolute path because .local/bin is not on PATH at this point
~/.local/bin/mise install

# prune old tools
~/.local/bin/mise prune --yes
